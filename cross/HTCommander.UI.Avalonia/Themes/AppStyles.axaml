<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Shared visual language for HTCommander. Brushes live in App.axaml resources;
         this file holds reusable control styling and Classes so every tab looks
         consistent without repeating hex colors in markup. -->

    <!-- Section heading: bold label above a panel/list -->
    <Style Selector="TextBlock.Section">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Muted helper / hint text -->
    <Style Selector="TextBlock.Hint">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- Card: a framed surface used for panels and list containers. Rounded with a
         soft drop shadow to match the mobile "beige + denim" card look. -->
    <Style Selector="Border.Card">
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="BoxShadow" Value="0 1 3 0 #14000000"/>
    </Style>

    <!-- A card that wraps a list: no padding so the list reaches the edges -->
    <Style Selector="Border.ListCard">
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="BoxShadow" Value="0 1 3 0 #14000000"/>
    </Style>

    <!-- Roomier, rounded text inputs in the mobile idiom (soft surface, denim focus) -->
    <Style Selector="TextBox">
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <!-- Accent (primary) button -->
    <Style Selector="Button.Accent">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.Accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
    </Style>

    <!-- Danger / on-air PTT button -->
    <Style Selector="Button.Ptt">
        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.Ptt:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
    </Style>
    <Style Selector="Button.Ptt:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource DangerActiveBrush}"/>
    </Style>

    <!-- Slightly roomier buttons everywhere -->
    <Style Selector="Button">
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <!-- Segmented control (mobile idiom): a rounded track holding mutually-exclusive
         RadioButtons that read as filled denim pills when selected. -->
    <Style Selector="Border.Seg">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Padding" Value="3"/>
    </Style>
    <Style Selector="RadioButton.seg">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Padding" Value="14,4"/>
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <!-- Hide the default radio glyph; the button body IS the indicator. -->
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="segRoot" Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Content="{TemplateBinding Content}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="RadioButton.seg:pointerover /template/ Border#segRoot">
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
    </Style>
    <Style Selector="RadioButton.seg:checked">
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="RadioButton.seg:checked /template/ Border#segRoot">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
    </Style>

    <!-- Connection status pill (mobile top-bar idiom): a rounded chip with a state dot. -->
    <Style Selector="Border.Pill">
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="11,5"/>
    </Style>

    <!-- Tabs: roomier headers -->
    <Style Selector="TabItem">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <!-- Chromeless TabControl: hide the built-in tab strip so the left nav rail
         drives selection instead (the TabControl is now just a content host). -->
    <Style Selector="TabControl.chromeless /template/ ItemsPresenter#PART_ItemsPresenter">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- Left navigation rail (SplitView pane) -->
    <Style Selector="TextBlock.NavGroup">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="12,12,0,4"/>
    </Style>
    <Style Selector="ListBox.nav">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="ListBox.nav ListBoxItem">
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="Margin" Value="6,1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- ListBox inside a ListCard: transparent so the card surface shows -->
    <Style Selector="Border.ListCard > ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- Channel cards (memory-slot tiles), styled after the Windows channel grid -->
    <Style Selector="Border.Chan">
        <Setter Property="Width" Value="104"/>
        <Setter Property="Height" Value="46"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="#e3e9f0"/>      <!-- programmed: denim tint -->
        <Setter Property="BorderBrush" Value="#c0cedd"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>
    <Style Selector="Border.Chan.empty">
        <Setter Property="Background" Value="#ece3cf"/>       <!-- empty slot: recessed beige -->
        <Setter Property="BorderBrush" Value="#ddd0b5"/>
    </Style>
    <Style Selector="Border.Chan.active">
        <Setter Property="Background" Value="#5BA845"/>       <!-- current channel: green -->
        <Setter Property="BorderBrush" Value="#4d9239"/>
    </Style>
    <Style Selector="Border.Chan TextBlock.cname">
        <Setter Property="Foreground" Value="#1A1A1A"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>
    <Style Selector="Border.Chan.empty TextBlock.cname">
        <Setter Property="Foreground" Value="#a99e84"/>
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>
    <Style Selector="Border.Chan TextBlock.cfreq">
        <Setter Property="Foreground" Value="#333"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>
    <Style Selector="Border.Chan.empty TextBlock.cfreq"><Setter Property="Foreground" Value="#a99e84"/></Style>
    <!-- drop hover highlight -->
    <Style Selector="Border.Chan.dragover">
        <Setter Property="Background" Value="#42648f"/>
    </Style>
</Styles>
