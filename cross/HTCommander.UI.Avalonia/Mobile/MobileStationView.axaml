<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HTCommander.UI.Avalonia.ViewModels"
             x:Class="HTCommander.UI.Avalonia.Mobile.MobileStationView"
             x:DataType="vm:MainViewModel">
  <ScrollViewer>
    <StackPanel Margin="14" Spacing="14">
      <TextBlock Classes="mSection" Text="IDENTITY"/>
      <StackPanel Spacing="6">
        <TextBlock Classes="mKey" Text="CALLSIGN"/>
        <TextBox Classes="mInput" Text="{Binding MyCallsign}" Watermark="e.g. KE4AXW"/>
      </StackPanel>
      <StackPanel Spacing="6">
        <TextBlock Classes="mKey" Text="STATION ID (SSID)"/>
        <ComboBox Classes="mInput" ItemsSource="{Binding StationIdOptions}" SelectedItem="{Binding MyStationId}"/>
      </StackPanel>
      <StackPanel Spacing="6">
        <TextBlock Classes="mKey" Text="WINLINK PASSWORD"/>
        <TextBox Classes="mInput" Text="{Binding WinlinkPassword}" PasswordChar="•"/>
      </StackPanel>
      <Border Classes="mCard">
        <StackPanel Spacing="6">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Allow transmit" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AllowTransmit}" OnContent="" OffContent=""/>
          </Grid>
          <TextBlock Classes="mKey" TextWrapping="Wrap"
                     Text="I am licensed and authorized to transmit. Required (with a callsign) before any on-air TX."/>
        </StackPanel>
      </Border>

      <TextBlock Classes="mSection" Text="APRS" Margin="2,8,0,8"/>
      <StackPanel Spacing="6">
        <TextBlock Classes="mKey" Text="APRS CHANNEL (FOR MESSAGES + BEACON)"/>
        <ComboBox Classes="mInput" ItemsSource="{Binding ChannelNames}" SelectedItem="{Binding AprsChannelName}"/>
      </StackPanel>

      <TextBlock Classes="mSection" Text="FIXED POSITION (NO GPS)" Margin="2,8,0,8"/>
      <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
        <StackPanel Grid.Column="0" Spacing="6"><TextBlock Classes="mKey" Text="LATITUDE"/>
          <TextBox Classes="mInput" Text="{Binding ManualLatitude}" Watermark="35.7796"/></StackPanel>
        <StackPanel Grid.Column="1" Spacing="6"><TextBlock Classes="mKey" Text="LONGITUDE"/>
          <TextBox Classes="mInput" Text="{Binding ManualLongitude}" Watermark="-78.6382"/></StackPanel>
      </Grid>
      <Button x:Name="SetFixedButton" Classes="mGhost" Content="Set fixed position on radio" IsEnabled="{Binding CanRequestPosition}"/>

      <!-- APRS beacon: choose how your position is transmitted -->
      <TextBlock Classes="mSection" Text="APRS BEACON" Margin="2,8,0,0"/>
      <StackPanel Spacing="6">
        <TextBlock Classes="mKey" Text="BEACON METHOD"/>
        <ComboBox Classes="mInput" ItemsSource="{Binding BeaconModes}" SelectedItem="{Binding BeaconMode}"/>
      </StackPanel>
      <Border Classes="mCard">
        <TextBlock Classes="mKey" TextWrapping="Wrap"
                   Text="App (TNC): the app sends your position via the radio's data TNC — works alongside Winlink / BBS / APRS messages (radio Digital mode OFF). Radio (built-in): the radio beacons on its own, but needs Digital mode ON, which DISABLES the TNC (Winlink/BBS/messages stop)."/>
      </Border>

      <!-- Shared beacon details -->
      <StackPanel Spacing="14">
        <Border Classes="mCard">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Share my location" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding BeaconShareLocation}" OnContent="" OffContent=""/>
          </Grid>
        </Border>
        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
          <StackPanel Grid.Column="0" Spacing="6"><TextBlock Classes="mKey" Text="APRS SYMBOL"/>
            <TextBox Classes="mInput" Text="{Binding BeaconSymbol}" MaxLength="2"/></StackPanel>
          <StackPanel Grid.Column="1" Spacing="6"><TextBlock Classes="mKey" Text="INTERVAL (S)"/>
            <TextBox Classes="mInput" Text="{Binding BeaconInterval}"/></StackPanel>
        </Grid>
        <StackPanel Spacing="6"><TextBlock Classes="mKey" Text="BEACON COMMENT"/>
          <TextBox Classes="mInput" Text="{Binding BeaconMessageText}" MaxLength="18"/></StackPanel>
      </StackPanel>

      <!-- App (TNC) beacon controls -->
      <StackPanel Spacing="10" IsVisible="{Binding IsAppBeacon}">
        <Button x:Name="BeaconNowButton" Classes="mPri" Content="📍 Beacon now" IsEnabled="{Binding CanBeacon}"/>
        <Border Classes="mCard">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Auto-beacon (every interval)" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoBeacon}" IsEnabled="{Binding CanBeacon}" OnContent="" OffContent=""/>
          </Grid>
        </Border>
      </StackPanel>

      <!-- Radio (built-in) beacon controls -->
      <StackPanel Spacing="10" IsVisible="{Binding IsRadioBeacon}">
        <Border Classes="mCard">
          <TextBlock Classes="mKey" TextWrapping="Wrap" Foreground="#7a5a16"
                     Text="⚠ Requires Digital mode ON in the radio's menu, which disables the TNC — Winlink, BBS and APRS messages will stop working until it's OFF again."/>
        </Border>
        <Button x:Name="WriteBssButton" Classes="mPri" Content="⬆ Write beacon to radio" IsEnabled="{Binding CanWriteBss}"/>
      </StackPanel>

      <TextBlock Classes="mKey" TextWrapping="Wrap" Margin="0,4,0,0"
                 Text="Settings save automatically. Named APRS digipeater routes are configured on the desktop app."/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
