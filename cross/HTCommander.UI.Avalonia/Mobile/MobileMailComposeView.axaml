<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HTCommander.UI.Avalonia.ViewModels"
             xmlns:core="using:HTCommander"
             x:Class="HTCommander.UI.Avalonia.Mobile.MobileMailComposeView"
             x:DataType="vm:MainViewModel">
  <ScrollViewer>
    <StackPanel Margin="14" Spacing="12">
      <StackPanel Spacing="6"><TextBlock Classes="mKey" Text="TO (CALLSIGN OR EMAIL)"/>
        <TextBox Classes="mInput" Text="{Binding ComposeTo}"/></StackPanel>
      <StackPanel Spacing="6"><TextBlock Classes="mKey" Text="SUBJECT"/>
        <TextBox Classes="mInput" Text="{Binding ComposeSubject}"/></StackPanel>
      <StackPanel Spacing="6"><TextBlock Classes="mKey" Text="MESSAGE"/>
        <TextBox Classes="mInput" Text="{Binding ComposeBody}" AcceptsReturn="True" Height="180" TextWrapping="Wrap"/></StackPanel>

      <StackPanel Spacing="8" IsVisible="{Binding HasComposeAttachments}">
        <TextBlock Classes="mSection" Text="ATTACHMENTS"/>
        <ListBox Classes="mInput" MaxHeight="120" ItemsSource="{Binding ComposeAttachments}" SelectedItem="{Binding SelectedComposeAttachment}">
          <ListBox.ItemTemplate><DataTemplate x:DataType="core:WinLinkMailAttachement"><TextBlock Text="{Binding Name}"/></DataTemplate></ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>
      <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
        <Button Grid.Column="0" x:Name="AttachButton" Classes="mGhost" Content="Attach…"/>
        <Button Grid.Column="1" x:Name="AttachRemoveButton" Classes="mGhost" Content="Remove attachment"/>
      </Grid>

      <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,4,0,0">
        <Button Grid.Column="0" x:Name="OutboxButton" Classes="mPri" Content="Save to Outbox"/>
        <Button Grid.Column="1" x:Name="DraftButton" Classes="mGhost" Content="Save as Draft"/>
      </Grid>
      <TextBlock Classes="mKey" TextWrapping="Wrap" Text="Outbox messages are sent on the next sync; Drafts are not sent."/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
