<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HTCommander.UI.Avalonia.ViewModels"
             xmlns:core="using:HTCommander"
             x:Class="HTCommander.UI.Avalonia.Mobile.MobileMailView"
             x:DataType="vm:MainViewModel">
  <Grid RowDefinitions="Auto,Auto,*" Margin="14,12">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,0,0,8">
      <ComboBox Grid.Column="0" Classes="mInput" ItemsSource="{Binding Folders}" SelectedItem="{Binding SelectedFolder}">
        <ComboBox.ItemTemplate><DataTemplate x:DataType="vm:MailFolder"><TextBlock Text="{Binding Display}"/></DataTemplate></ComboBox.ItemTemplate>
      </ComboBox>
      <Button Grid.Column="1" x:Name="SyncButton" Classes="mGhost" Content="⇅ Sync" Padding="14,0"/>
    </Grid>
    <Button Grid.Row="1" x:Name="ComposeButton" Classes="mPri" Content="✎  Compose" Margin="0,0,0,10"/>
    <ScrollViewer Grid.Row="2">
      <ItemsControl x:Name="MailList" ItemsSource="{Binding Mails}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="core:WinLinkMail">
            <Button Classes="rowBtn">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <Ellipse Grid.Column="0" Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,10,0"
                         Fill="{StaticResource MAccent}" IsVisible="{Binding IsUnread}"/>
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{Binding Subject}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                  <TextBlock Text="{Binding From}" FontSize="12.5" Foreground="{StaticResource MMut}" FontFamily="{StaticResource MMono}"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding DateTime, StringFormat='{}{0:MM-dd HH:mm}'}" FontSize="11" Foreground="{StaticResource MDim}" VerticalAlignment="Center"/>
              </Grid>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
