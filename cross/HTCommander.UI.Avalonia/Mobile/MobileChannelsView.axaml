<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HTCommander.UI.Avalonia.ViewModels"
             x:Class="HTCommander.UI.Avalonia.Mobile.MobileChannelsView"
             x:DataType="vm:MainViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="14,12">
    <Grid Grid.Row="0" ColumnDefinitions="*,*" ColumnSpacing="8">
      <Button Grid.Column="0" x:Name="ImportButton" Classes="mPri" Content="⬆ Import CSV"/>
      <Button Grid.Column="1" x:Name="LoadButton" Classes="mGhost" Content="⟳ Load from radio"/>
    </Grid>
    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Margin="0,8,0,0" IsVisible="{Binding HasBanks}">
      <TextBlock Grid.Column="0" Classes="mKey" Text="BANK" VerticalAlignment="Center"/>
      <ComboBox Grid.Column="1" Classes="mInput" ItemsSource="{Binding Banks}" SelectedItem="{Binding SelectedBank}"/>
      <Button Grid.Column="2" x:Name="LoadAllButton" Classes="mGhost" Content="Load all banks" IsEnabled="{Binding CanLoadAllBanks}" Padding="14,0"/>
    </Grid>
    <TextBlock Grid.Row="2" Classes="mKey" Text="{Binding BuilderStatus}" TextWrapping="Wrap" Margin="2,8,2,8"/>

    <ScrollViewer Grid.Row="3">
      <ItemsControl x:Name="SlotList" ItemsSource="{Binding Slots}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ChannelSlot">
            <Button Classes="rowBtn">
              <Grid ColumnDefinitions="48,*,Auto,Auto">
                <Border Grid.Column="0" Width="44" Height="40" CornerRadius="10" VerticalAlignment="Center"
                        Background="{StaticResource MTint}" BorderBrush="{StaticResource MTintLine}" BorderThickness="1">
                  <TextBlock Text="{Binding SlotId}" FontFamily="{StaticResource MMono}" FontWeight="Bold"
                             Foreground="{StaticResource MAccent}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding Display}" FontWeight="SemiBold" FontFamily="{StaticResource MMono}"/>
                  <TextBlock Text="{Binding FreqText, StringFormat='{}{0} MHz'}" FontSize="12.5" Foreground="{StaticResource MMut}" FontFamily="{StaticResource MMono}"/>
                </StackPanel>
                <Border Grid.Column="2" IsVisible="{Binding IsActive}" Background="#e2efe7" BorderBrush="#bcdcc8" BorderThickness="1"
                        CornerRadius="6" Padding="6,1" VerticalAlignment="Center" Margin="0,0,8,0">
                  <TextBlock Text="LIVE" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource MGood}"/>
                </Border>
                <TextBlock Grid.Column="3" Classes="chev" Text="›"/>
              </Grid>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Button Grid.Row="4" x:Name="WriteAllButton" Classes="mPri" Content="⬆ Write all to radio" Margin="0,10,0,0"/>
  </Grid>
</UserControl>
