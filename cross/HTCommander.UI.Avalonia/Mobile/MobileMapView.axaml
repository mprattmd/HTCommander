<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HTCommander.UI.Avalonia.ViewModels"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Avalonia;assembly=Mapsui.UI.Avalonia"
             x:Class="HTCommander.UI.Avalonia.Mobile.MobileMapView"
             x:DataType="vm:MainViewModel">
  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0" Background="{StaticResource MS1}" BorderBrush="{StaticResource MLine}" BorderThickness="0,0,0,1" Padding="10,8">
      <StackPanel Spacing="8">
        <TextBox Classes="mInput" Text="{Binding AprsFiCallsigns}" Watermark="aprs.fi callsigns (comma-separated)"/>
        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
          <Button Grid.Column="0" x:Name="LookUpButton" Classes="mGhost" Content="Look up (aprs.fi)" VerticalAlignment="Center"/>
          <Button Grid.Column="1" x:Name="CenterGpsButton" Classes="mGhost" Content="📍 Center on GPS" VerticalAlignment="Center" IsEnabled="{Binding CanCenterGps}"/>
        </Grid>
        <TextBlock Text="{Binding AprsFiStatus}" Classes="mKey" Foreground="{StaticResource MAccent}" IsVisible="{Binding AprsFiStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
      </StackPanel>
    </Border>
    <mapsui:MapControl Grid.Row="1" x:Name="MapControl"/>
  </Grid>
</UserControl>
