<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:HTCommander.UI.Avalonia.Converters"
             x:Class="HTCommander.UI.Avalonia.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <!-- Show 0-based radio indices (channel/bank) as 1-based for humans; wire stays 0-based. -->
        <conv:PlusOneConverter x:Key="PlusOne"/>
        <!-- Centralized palette. Desktop and mobile now share one light "beige +
             denim" look: the desktop brush keys below are mapped onto the same
             M* tokens the Android pages use, so both heads render identically.
             Referenced via DynamicResource in AppStyles + markup. -->
        <Color x:Key="SystemAccentColor">#42648f</Color>
        <Color x:Key="SystemAccentColorDark1">#33506f</Color>

        <!-- Desktop keys re-pointed onto the beige+denim palette (was a dark theme). -->
        <SolidColorBrush x:Key="Surface0Brush" Color="#f1e9d8"/>   <!-- MBg: window -->
        <SolidColorBrush x:Key="Surface1Brush" Color="#e8ddc6"/>   <!-- MS1: bars / nav rail -->
        <SolidColorBrush x:Key="Surface2Brush" Color="#fdfbf3"/>   <!-- MCard: cards -->
        <SolidColorBrush x:Key="BorderBrush" Color="#d9ccb0"/>     <!-- MLine -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#2e2a1f"/><!-- MTxt -->
        <SolidColorBrush x:Key="TextMutedBrush" Color="#7d745d"/>  <!-- MMut -->
        <SolidColorBrush x:Key="AccentBrush" Color="#42648f"/>     <!-- MAccent: denim -->
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#33506f"/><!-- MAccent2 -->
        <SolidColorBrush x:Key="DangerBrush" Color="#cf5046"/>     <!-- MDanger -->
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#d65b51"/>
        <SolidColorBrush x:Key="DangerActiveBrush" Color="#e0655b"/>
        <SolidColorBrush x:Key="GoodBrush" Color="#3a8f63"/>       <!-- MGood -->
        <SolidColorBrush x:Key="InfoBrush" Color="#42648f"/>       <!-- denim (was light blue) -->
        <!-- Warning (caution banners / hints): readable amber on beige. -->
        <SolidColorBrush x:Key="WarnBrush" Color="#8a6a16"/>
        <SolidColorBrush x:Key="WarnBgBrush" Color="#f6e8c8"/>
        <SolidColorBrush x:Key="WarnBorderBrush" Color="#d8b25a"/>

        <!-- Mobile (Android) palette: light "beige + denim". Global so every mobile
             page resolves them at load time (pages aren't in the tree when parsed). -->
        <SolidColorBrush x:Key="MBg" Color="#f1e9d8"/>
        <SolidColorBrush x:Key="MS1" Color="#e8ddc6"/>
        <SolidColorBrush x:Key="MS2" Color="#f6efdf"/>
        <SolidColorBrush x:Key="MCard" Color="#fdfbf3"/>
        <SolidColorBrush x:Key="MLine" Color="#d9ccb0"/>
        <SolidColorBrush x:Key="MTxt" Color="#2e2a1f"/>
        <SolidColorBrush x:Key="MMut" Color="#7d745d"/>
        <SolidColorBrush x:Key="MDim" Color="#a99e84"/>
        <SolidColorBrush x:Key="MAccent" Color="#42648f"/>
        <SolidColorBrush x:Key="MAccent2" Color="#33506f"/>
        <SolidColorBrush x:Key="MTint" Color="#e3e9f0"/>
        <SolidColorBrush x:Key="MTintLine" Color="#c0cedd"/>
        <SolidColorBrush x:Key="MGood" Color="#3a8f63"/>
        <SolidColorBrush x:Key="MDanger" Color="#cf5046"/>
        <FontFamily x:Key="MMono">monospace</FontFamily>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <StyleInclude Source="avares://HTCommander.UI.Avalonia/Themes/AppStyles.axaml"/>
    </Application.Styles>
</Application>
