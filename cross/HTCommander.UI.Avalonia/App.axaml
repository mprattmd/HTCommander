<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:HTCommander.UI.Avalonia.Converters"
             x:Class="HTCommander.UI.Avalonia.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- Show 0-based radio indices (channel/bank) as 1-based for humans; wire stays 0-based. -->
        <conv:PlusOneConverter x:Key="PlusOne"/>
        <!-- Centralized palette. Surfaces go dark->light by tier; accent is a
             ham-radio blue. Referenced via DynamicResource in AppStyles + markup. -->
        <Color x:Key="SystemAccentColor">#2F80ED</Color>
        <Color x:Key="SystemAccentColorDark1">#2A75D6</Color>

        <SolidColorBrush x:Key="Surface0Brush" Color="#1B1B1F"/>
        <SolidColorBrush x:Key="Surface1Brush" Color="#232327"/>
        <SolidColorBrush x:Key="Surface2Brush" Color="#2A2A30"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A42"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F2F2F4"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9A9AA6"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2F80ED"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#3A8BF5"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#C0392B"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#D14333"/>
        <SolidColorBrush x:Key="DangerActiveBrush" Color="#E74C3C"/>
        <SolidColorBrush x:Key="GoodBrush" Color="#27AE60"/>
        <SolidColorBrush x:Key="InfoBrush" Color="#9CDCFE"/>

        <!-- Mobile (Android) palette: light "beige + denim". Global so every mobile
             page resolves them at load time (pages aren't in the tree when parsed). -->
        <SolidColorBrush x:Key="MBg" Color="#f1e9d8"/>
        <SolidColorBrush x:Key="MS1" Color="#e8ddc6"/>
        <SolidColorBrush x:Key="MS2" Color="#f6efdf"/>
        <SolidColorBrush x:Key="MCard" Color="#fdfbf3"/>
        <SolidColorBrush x:Key="MLine" Color="#d9ccb0"/>
        <SolidColorBrush x:Key="MTxt" Color="#2e2a1f"/>
        <SolidColorBrush x:Key="MMut" Color="#7d745d"/>
        <SolidColorBrush x:Key="MDim" Color="#a99e84"/>
        <SolidColorBrush x:Key="MAccent" Color="#42648f"/>
        <SolidColorBrush x:Key="MAccent2" Color="#33506f"/>
        <SolidColorBrush x:Key="MTint" Color="#e3e9f0"/>
        <SolidColorBrush x:Key="MTintLine" Color="#c0cedd"/>
        <SolidColorBrush x:Key="MGood" Color="#3a8f63"/>
        <SolidColorBrush x:Key="MDanger" Color="#cf5046"/>
        <FontFamily x:Key="MMono">monospace</FontFamily>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <StyleInclude Source="avares://HTCommander.UI.Avalonia/Themes/AppStyles.axaml"/>
    </Application.Styles>
</Application>
