<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HTCommander.UI.Avalonia.ViewModels"
        xmlns:ui="using:HTCommander.UI.Avalonia"
        x:Class="HTCommander.UI.Avalonia.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1100" Height="720"
        Icon="/Assets/HTCommander.ico"
        Background="{DynamicResource Surface0Brush}"
        Title="{Binding WindowTitle}">
    <!-- Desktop host: the shared UI lives in MainView (also hosted by the Android
         single-view lifetime). The view model is set as DataContext by App and
         inherits down into MainView. -->
    <ui:MainView/>
</Window>
