<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:HTCommander.UI.Avalonia.ViewModels"
        xmlns:pl="using:HTCommander.Platform.Linux"
        xmlns:audio="using:HTCommander.Core.Abstractions.Audio"
        xmlns:core="using:HTCommander"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="HTCommander.UI.Avalonia.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="900" Height="600"
        Title="HTCommander">
    <DockPanel LastChildFill="True">

        <!-- Connection bar -->
        <Border DockPanel.Dock="Top" Padding="8" Background="#2D2D30">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Radio:" VerticalAlignment="Center" Foreground="White"/>
                <ComboBox x:Name="RadioCombo" MinWidth="240"
                          ItemsSource="{Binding Radios}"
                          SelectedItem="{Binding SelectedRadio}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="pl:RadioDeviceInfo">
                            <TextBlock Text="{Binding Name}" ToolTip.Tip="{Binding Address}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button x:Name="RefreshButton" Content="Refresh"/>
                <Button x:Name="ConnectButton" Content="Connect"
                        IsEnabled="{Binding CanConnect}"/>
                <Button x:Name="DisconnectButton" Content="Disconnect"
                        IsEnabled="{Binding CanDisconnect}"/>
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                           Foreground="#9CDCFE" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="8,4" Background="#007ACC">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Foreground="White" Text="{Binding Status, StringFormat='State: {0}'}"/>
                <TextBlock Foreground="White" Text="{Binding FrameCount, StringFormat='Frames: {0}'}"/>
                <TextBlock Foreground="White" Text="{Binding BluetoothAvailable, StringFormat='Bluetooth: {0}'}"/>
            </StackPanel>
        </Border>

        <!-- Main tabbed area -->
        <TabControl>
            <TabItem Header="Radio">
                <Grid ColumnDefinitions="260,*" Margin="8" ColumnSpacing="10">

                    <!-- Live telemetry (parsed GET_HT_STATUS) -->
                    <Border Grid.Column="0" BorderBrush="#3F3F46" BorderThickness="1" Padding="10"
                            IsVisible="{Binding HasStatus}" VerticalAlignment="Top">
                        <Grid ColumnDefinitions="Auto,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="6" ColumnSpacing="12">
                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Radio status" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Power"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PowerText}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="State"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TxRxState}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Squelch"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SquelchText}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Channel"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ChannelId}"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="RSSI"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Rssi}"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Region"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Region}"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="GPS"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding GpsText}"/>
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Battery"/>
                            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding BatteryPercent, StringFormat='{}{0}%'}"/>
                            <TextBlock Grid.Row="9" Grid.ColumnSpan="2" Text="Device" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock Grid.Row="10" Grid.ColumnSpan="2" Text="{Binding DeviceInfoText}" TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <!-- Live transport log -->
                    <Grid Grid.Column="1" RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Margin="0,0,0,6"
                                   Text="Live transport log (BlueZ RFCOMM / GAIA frames)"
                                   FontWeight="Bold"/>
                        <Border Grid.Row="1" BorderBrush="#3F3F46" BorderThickness="1">
                            <ListBox ItemsSource="{Binding Log}" FontFamily="monospace"/>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Voice"><TextBlock Margin="12" Text="Voice — port pending (Phase 3)."/></TabItem>
            <TabItem Header="APRS"><TextBlock Margin="12" Text="APRS — port pending (Phase 3)."/></TabItem>
            <TabItem Header="Map"><TextBlock Margin="12" Text="Map (GMap.NET → Mapsui) — port pending (Phase 3)."/></TabItem>
            <TabItem Header="Mail"><TextBlock Margin="12" Text="Mail — port pending (Phase 3)."/></TabItem>
            <TabItem Header="Terminal"><TextBlock Margin="12" Text="Terminal — port pending (Phase 3)."/></TabItem>
            <TabItem Header="Contacts"><TextBlock Margin="12" Text="Contacts — port pending (Phase 3)."/></TabItem>
            <TabItem Header="BBS"><TextBlock Margin="12" Text="BBS — port pending (Phase 3)."/></TabItem>
            <TabItem Header="Channels">
                <Grid RowDefinitions="Auto,*" Margin="8">
                    <TextBlock Grid.Row="0" Margin="0,0,0,6" FontWeight="Bold"
                               Text="{Binding Channels.Count, StringFormat='Memory channels ({0})'}"/>
                    <Border Grid.Row="1" BorderBrush="#3F3F46" BorderThickness="1">
                        <ListBox ItemsSource="{Binding Channels}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="core:RadioChannelSummary">
                                    <Grid ColumnDefinitions="40,*,110,60" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0" Text="{Binding ChannelId}" Foreground="#888"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding RxMHz, StringFormat='{}{0:0.0000} MHz'}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Modulation}" Foreground="#9CDCFE"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Packets">
                <Grid RowDefinitions="Auto,*" Margin="8">
                    <TextBlock Grid.Row="0" Margin="0,0,0,6" FontWeight="Bold"
                               Text="{Binding Packets.Count, StringFormat='Received packets ({0})'}"/>
                    <Border Grid.Row="1" BorderBrush="#3F3F46" BorderThickness="1">
                        <ListBox ItemsSource="{Binding Packets}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="core:ReceivedPacketSummary">
                                    <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0" FontWeight="Bold" Text="{Binding Source}"/>
                                        <TextBlock Grid.Column="1" Foreground="#888"
                                                   Text="{Binding Destination, StringFormat='&gt; {0}'}"/>
                                        <TextBlock Grid.Column="2" Foreground="#9CDCFE" Text="APRS"
                                                   IsVisible="{Binding IsAprs}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Info}" TextWrapping="NoWrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Settings">
                <ScrollViewer>
                    <StackPanel Margin="16" Spacing="12" DataContext="{Binding Settings}"
                                x:DataType="vm:SettingsViewModel" MaxWidth="520" HorizontalAlignment="Left">
                        <TextBlock Text="Audio" FontWeight="Bold" FontSize="16"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Output device"/>
                            <ComboBox HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding OutputDevices}"
                                      SelectedItem="{Binding SelectedOutput}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="audio:AudioDevice">
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Input device"/>
                            <ComboBox HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding InputDevices}"
                                      SelectedItem="{Binding SelectedInput}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="audio:AudioDevice">
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding OutputVolumePercent, StringFormat='Output volume: {0}%'}"/>
                            <Slider Minimum="0" Maximum="150" Value="{Binding OutputVolumePercent}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button x:Name="TestToneButton" Content="Test tone"/>
                            <Button x:Name="RefreshDevicesButton" Content="Refresh devices"/>
                            <TextBlock Text="{Binding TestStatus}" VerticalAlignment="Center" Foreground="#9CDCFE"/>
                        </StackPanel>

                        <TextBlock Text="Settings persist to ~/.config/htcommander/ via JSON config."
                                   Foreground="#888" TextWrapping="Wrap" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
